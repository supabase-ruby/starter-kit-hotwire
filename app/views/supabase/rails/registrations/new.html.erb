<% content_for :auth_variant, "card" %>
<% content_for :auth_title, "Create an account" %>
<% content_for :auth_description, "Enter your details below to create your account" %>

<%= render AuthSessionStatusComponent.new(status: flash[:notice], class_name: "text-center") %>

<% if flash[:alert].present? %>
  <p class="font-medium text-sm text-red-600 text-center" data-test="register-error" data-testid="signup-error"><%= flash[:alert] %></p>
<% end %>

<%= form_with(url: registration_path, html: { class: "flex flex-col gap-6", "data-test": "register-form" }) do |form| %>
  <div class="flex flex-col gap-2">
    <%= form.label :email, "Email address", class: "text-sm font-medium text-zinc-900 dark:text-white" %>
    <%= form.email_field :email,
      value: params[:email],
      required: true,
      autofocus: true,
      autocomplete: "email",
      placeholder: "email@example.com",
      class: "block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900 dark:border-zinc-700 dark:bg-zinc-900 dark:text-white dark:placeholder:text-zinc-500 dark:focus:border-white dark:focus:ring-white",
      "data-test": "register-email-input",
      "data-testid": "signup-email-input" %>
  </div>

  <div class="flex flex-col gap-2">
    <%= form.label :password, "Password", class: "text-sm font-medium text-zinc-900 dark:text-white" %>
    <%= form.password_field :password,
      required: true,
      autocomplete: "new-password",
      placeholder: "Password",
      maxlength: 72,
      class: "block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900 dark:border-zinc-700 dark:bg-zinc-900 dark:text-white dark:placeholder:text-zinc-500 dark:focus:border-white dark:focus:ring-white",
      "data-test": "register-password-input",
      "data-testid": "signup-password-input" %>
    <p class="text-xs text-zinc-500 dark:text-zinc-400">12 characters minimum.</p>
  </div>

  <%= render ButtonComponent.new(label: "Create account", type: :submit, test_id: "signup-submit") %>
<% end %>

<div class="flex items-center gap-3">
  <%= render SeparatorComponent.new %>
  <span class="text-xs uppercase tracking-wide text-zinc-500 dark:text-zinc-400">or</span>
  <%= render SeparatorComponent.new %>
</div>

<%= render "supabase/rails/oauth/buttons" %>

<div class="text-center text-sm text-zinc-600 dark:text-zinc-400">
  <span>Already have an account?</span>
  <%= link_to "Log in", new_session_path, class: "font-medium text-zinc-900 underline-offset-4 hover:underline dark:text-white" %>
</div>

<div class="flex justify-center pt-2">
  <%= render AppLogoComponent.new %>
</div>
