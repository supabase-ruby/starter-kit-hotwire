<div data-test="welcome-page" class="flex w-full flex-col items-center lg:justify-center">
  <header data-test="welcome-header" class="w-full max-w-[335px] text-sm mb-6 lg:max-w-4xl">
    <nav class="flex items-center justify-end gap-4">
      <% if Current.user %>
        <%= link_to "Dashboard",
              dashboard_path,
              data: { test: "welcome-cta-dashboard" },
              class: "inline-block px-5 py-1.5 border-[#19140035] hover:border-[#1915014a] border rounded-sm text-sm leading-normal text-[#1b1b18] dark:text-[#EDEDEC] dark:border-[#3E3E3A] dark:hover:border-[#62605b]" %>
      <% else %>
        <%= link_to "Log in",
              sign_in_path,
              data: { test: "welcome-cta-login" },
              class: "inline-block px-5 py-1.5 border border-transparent hover:border-[#19140035] rounded-sm text-sm leading-normal text-[#1b1b18] dark:text-[#EDEDEC] dark:hover:border-[#3E3E3A]" %>
        <%= link_to "Register",
              sign_up_path,
              data: { test: "welcome-cta-register" },
              class: "inline-block px-5 py-1.5 border-[#19140035] hover:border-[#1915014a] border rounded-sm text-sm leading-normal text-[#1b1b18] dark:text-[#EDEDEC] dark:border-[#3E3E3A] dark:hover:border-[#62605b]" %>
      <% end %>
    </nav>
  </header>

  <div class="flex items-center justify-center w-full lg:grow">
    <main class="flex max-w-[335px] w-full flex-col-reverse lg:max-w-4xl lg:flex-row">
      <section class="text-[13px] leading-[20px] flex-1 p-6 pb-12 lg:p-20 bg-white dark:bg-[#161615] dark:text-[#EDEDEC] shadow-[inset_0px_0px_0px_1px_rgba(26,26,0,0.16)] dark:shadow-[inset_0px_0px_0px_1px_#fffaed2d] rounded-es-lg rounded-ee-lg lg:rounded-ss-lg lg:rounded-ee-none">
        <h1 class="mb-1 font-medium">Let's get started</h1>
        <p class="mb-2 text-[#706f6c] dark:text-[#A1A09A]">
          Rails has an incredibly rich ecosystem.<br>
          We suggest starting with the following.
        </p>
        <ul class="flex flex-col mb-4 lg:mb-6">
          <li class="flex items-center gap-4 py-2 relative before:border-l before:border-[#e3e3e0] dark:before:border-[#3E3E3A] before:top-1/2 before:bottom-0 before:left-[0.4rem] before:absolute">
            <span class="relative py-1 bg-white dark:bg-[#161615]">
              <span class="flex items-center justify-center rounded-full bg-[#FDFDFC] dark:bg-[#161615] w-3.5 h-3.5 border dark:border-[#3E3E3A] border-[#e3e3e0]">
                <span class="rounded-full bg-[#dbdbd7] dark:bg-[#3E3E3A] w-1.5 h-1.5"></span>
              </span>
            </span>
            <span>
              Read the
              <%= link_to "https://guides.rubyonrails.org", target: "_blank", rel: "noopener", class: "inline-flex items-center space-x-1 font-medium underline underline-offset-4 text-[#D30001] dark:text-[#FF4433] ms-1" do %>
                <span>Documentation</span>
              <% end %>
            </span>
          </li>
          <li class="flex items-center gap-4 py-2 relative before:border-l before:border-[#e3e3e0] dark:before:border-[#3E3E3A] before:bottom-1/2 before:top-0 before:left-[0.4rem] before:absolute">
            <span class="relative py-1 bg-white dark:bg-[#161615]">
              <span class="flex items-center justify-center rounded-full bg-[#FDFDFC] dark:bg-[#161615] w-3.5 h-3.5 border dark:border-[#3E3E3A] border-[#e3e3e0]">
                <span class="rounded-full bg-[#dbdbd7] dark:bg-[#3E3E3A] w-1.5 h-1.5"></span>
              </span>
            </span>
            <span>
              Watch screencasts at
              <%= link_to "https://gorails.com", target: "_blank", rel: "noopener", class: "inline-flex items-center space-x-1 font-medium underline underline-offset-4 text-[#D30001] dark:text-[#FF4433] ms-1" do %>
                <span>GoRails</span>
              <% end %>
            </span>
          </li>
        </ul>
        <ul class="flex gap-3 text-sm leading-normal">
          <li>
            <%= link_to "Deploy now",
                  "https://kamal-deploy.org",
                  target: "_blank",
                  rel: "noopener",
                  class: "inline-block px-5 py-1.5 bg-[#1b1b18] rounded-sm border border-black text-white text-sm leading-normal hover:bg-black hover:border-black dark:bg-[#eeeeec] dark:border-[#eeeeec] dark:text-[#1C1C1A] dark:hover:bg-white dark:hover:border-white" %>
          </li>
        </ul>
      </section>
      <aside class="bg-[#fff2f2] dark:bg-[#1D0002] relative lg:-ml-px -mb-px lg:mb-0 rounded-t-lg lg:rounded-t-none lg:rounded-r-lg aspect-[335/364] lg:aspect-auto w-full lg:w-[438px] shrink-0 overflow-hidden flex items-center justify-center">
        <div class="text-[#D30001] dark:text-[#F61500] font-semibold text-4xl lg:text-6xl tracking-tight">
          Rails Starter Kit
        </div>
        <div class="absolute inset-0 rounded-t-lg lg:rounded-t-none lg:rounded-r-lg shadow-[inset_0px_0px_0px_1px_rgba(26,26,0,0.16)] dark:shadow-[inset_0px_0px_0px_1px_#fffaed2d]"></div>
      </aside>
    </main>
  </div>
</div>
