# Copy this file to `.env` and fill in values as needed.
# `.env` is gitignored. Rails does not auto-load .env — export these in
# your shell (e.g. via `direnv`, `dotenv`, or your process manager) before
# running `bin/dev` / `bin/rails server`.

# --- Rails -------------------------------------------------------------------

# Rails environment: development | test | production
RAILS_ENV=development

# Decrypts config/credentials.yml.enc. REQUIRED in production.
# Generate with `bin/rails credentials:edit` (writes config/master.key).
# RAILS_MASTER_KEY=

# Log verbosity in production. development/test ignore this.
# RAILS_LOG_LEVEL=info

# --- Server / Puma -----------------------------------------------------------

# HTTP port for `bin/rails server` / Puma.
PORT=3000

# Number of Puma worker processes. Default 1. Set to `auto` to scale to CPUs.
# WEB_CONCURRENCY=1

# Threads per Puma worker. Also used as Active Record connection pool size.
RAILS_MAX_THREADS=3

# Set to any truthy value to run Solid Queue inside the Puma process
# (single-server deployments).
# SOLID_QUEUE_IN_PUMA=

# Optional PID file path.
# PIDFILE=tmp/pids/server.pid

# --- Database ----------------------------------------------------------------

# By default the app uses SQLite (see config/database.yml). Set DATABASE_URL
# to override (e.g. postgres://user:pass@host:5432/dbname).
# DATABASE_URL=

# --- Supabase ----------------------------------------------------------------

# Project URL from the Supabase dashboard (Project Settings → API).
SUPABASE_URL=

# Public anon key — safe to expose to browsers. Used by the gem for
# user-scoped requests (sign-in, sign-up, etc.).
SUPABASE_ANON_KEY=

# Service role key — server-only, NEVER expose to clients. Used by the gem
# for admin-side calls (e.g. updating user metadata via the admin API).
SUPABASE_SERVICE_ROLE_KEY=

# --- Test --------------------------------------------------------------------

# Set in CI to enable eager loading in the test environment.
# CI=true
