# Copy to `.env.e2e` and source before running `bin/e2e` if you want to
# override the values that `bin/e2e` pulls from `supabase status --output env`.
# Rails does not auto-load this file — export via `direnv`/`dotenv` yourself.
#
# Normal flow: `bin/e2e bin/rails test` starts (or reuses) the local Supabase
# stack, parses `supabase status --output env`, and exports the variables
# below before invoking the command. Setting them ahead of time short-circuits
# the parse (the values already in your shell win).

# --- Rails -------------------------------------------------------------------

# `bin/e2e` sets this for the child process; uncomment to also run interactive
# tasks like `bin/rails console -e e2e` in the same environment.
# RAILS_ENV=e2e

# --- Supabase (sourced from `supabase status --output env`) ------------------

# Local API gateway URL. Default printed by `supabase status` is
# http://127.0.0.1:54321 — override only if you've remapped Kong's port.
SUPABASE_URL=http://127.0.0.1:54321

# Local anon (publishable) JWT. Printed as `ANON_KEY` by `supabase status`.
# Safe to expose to browsers; used for user-scoped requests.
SUPABASE_ANON_KEY=

# Local service-role JWT. Printed as `SERVICE_ROLE_KEY` by `supabase status`.
# Server-only; NEVER expose to clients. Used for admin-side calls.
SUPABASE_SERVICE_ROLE_KEY=

# --- Test harness ------------------------------------------------------------

# Seconds `bin/e2e` waits for `supabase start` on a cold boot. Bump on slow
# machines or first-time image pulls.
# E2E_SUPABASE_TIMEOUT=120
